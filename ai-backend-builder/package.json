{
  "name": "ai-backend-builder",
  "displayName": "AI Backend Builder",
  "description": "Autonomous multi-agent system that plans, generates, and debugs production-ready Node.js/Express backend applications using AI",
  "version": "0.1.0",
  "publisher": "jaydee",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Machine Learning",
    "Programming Languages"
  ],
  "keywords": [
    "ai",
    "backend",
    "express",
    "nodejs",
    "code-generation",
    "multi-agent"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aiBackendBuilder.buildBackend",
        "title": "Build Backend with AI"
      }
    ],
    "configuration": {
      "title": "AI Backend Builder",
      "properties": {
        "aiBackendBuilder.flaskUrl": {
          "type": "string",
          "default": "http://localhost:5000",
          "description": "Base URL for the local Flask AI API proxy"
        },
        "aiBackendBuilder.openaiApiKey": {
          "type": "string",
          "default": "",
          "description": "OpenAI API key (fallback when Flask API is unavailable)"
        },
        "aiBackendBuilder.openaiModel": {
          "type": "string",
          "default": "gpt-4",
          "description": "OpenAI model to use as fallback"
        },
        "aiBackendBuilder.models.planner": {
          "type": "string",
          "default": "mistral:7b",
          "description": "Local model name for the Planner Agent"
        },
        "aiBackendBuilder.models.codegen": {
          "type": "string",
          "default": "codellama:13b",
          "description": "Local model name for the Code Generator Agent"
        },
        "aiBackendBuilder.models.debug": {
          "type": "string",
          "default": "mistral:7b",
          "description": "Local model name for the Debug Agent"
        },
        "aiBackendBuilder.maxRetries": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 10,
          "description": "Maximum number of debug-fix retry attempts"
        },
        "aiBackendBuilder.debugTimeout": {
          "type": "number",
          "default": 10000,
          "minimum": 3000,
          "maximum": 60000,
          "description": "Timeout (ms) for running the generated app during debugging"
        },
        "aiBackendBuilder.aiRequestTimeout": {
          "type": "number",
          "default": 120000,
          "minimum": 30000,
          "maximum": 600000,
          "description": "Timeout (ms) for AI model requests"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.3"
  }
}
